parameters:
    level: 8
    paths:
        - src
        - config
        - tests
    symfony:
        containerXmlPath: var/cache/dev/App_KernelDevDebugContainer.xml
    ignoreErrors:
        -
            message: '#has parameter \$builder with no value type specified in iterable type array#'
            path: src/Form/

includes:
    - vendor/phpstan/phpstan-symfony/extension.neon
    - vendor/phpstan/phpstan-doctrine/extension.neon
